# ----------------------------------------------------
# 晨間儀表板 .gitignore
# ----------------------------------------------------

# 敏感資訊設定檔 (內含 API 網址與金鑰)
config.js

# 資料備份或本地測試資料
data.js
*.pyc
__pycache__/

# 系統檔案
.DS_Store
Thumbs.db

# 編輯器/IDE 相關
.vscode/
.idea/
*.swp
*.bak

# 相依套件 (若後續改為 npm 專案)
node_modules/
